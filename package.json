{
  "name": "amiriel",
  "version": "0.0.1-beta.6",
  "description": "Meta package that re-exports @amiriel/core for npm install amiriel.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://amiriel.com",
  "packageManager": "pnpm@11.7.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amirieljs/Amiriel.git"
  },
  "bugs": {
    "url": "https://github.com/Amirieljs/Amiriel/issues"
  },
  "keywords": [
    "amiriel",
    "letter-editor",
    "document-model",
    "typescript",
    "framework-agnostic"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "sideEffects": false,
  "dependencies": {
    "@amiriel/core": "^0.0.1-beta.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
