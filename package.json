{
  "name": "amiriel",
  "version": "0.0.1-beta.5",
  "description": "Portable Vue 3 body editor and renderer for Amiriel letters.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://amiriel.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dingdangdog/Amiriel.git"
  },
  "bugs": {
    "url": "https://github.com/dingdangdog/Amiriel/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-component",
    "editor",
    "letter-editor",
    "rich-text",
    "typescript",
    "vite"
  ],
  "main": "./dist/amiriel.umd.cjs",
  "module": "./dist/amiriel.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/amiriel.js",
      "require": "./dist/amiriel.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "dependencies": {
    "@heroicons/vue": "2.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vue": "^3.5.34",
    "vue-tsc": "^3.1.8"
  }
}
